# Razorpay (REQUIRED for live payments)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Admin
ADMIN_PIN=1234
ADMIN_PATTERN=1235789
ADMIN_SESSION_SECRET=generate-a-random-32-char-string-here

# Cloudflare Tunnel public URL (used for QR code generation)
TUNNEL_URL=https://print.yourdomain.com

# Printer
DEFAULT_PRINTER=PrinterName_Here

# Pricing fallback (if no rule matches)
PRICE_PER_PAGE=2.0

# App
ENV=production
LOG_LEVEL=INFO
